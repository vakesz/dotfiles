# Theme
theme = Xcode Dark hc

# Font
font-family = FiraCode Nerd Font Mono
font-size = 16
font-style = Reg
font-style-bold = Bold
font-style-italic = Reg
font-style-bold-italic = Bold
font-feature = calt
font-feature = liga
font-thicken = true

# Cursor
cursor-style-blink = false

# Window
window-padding-x = 8
window-padding-y = 8
confirm-close-surface = false
window-inherit-working-directory = true

# macOS
macos-titlebar-style = tabs
macos-titlebar-proxy-icon = visible
macos-icon = blueprint

# Input
mouse-hide-while-typing = true
copy-on-select = true
clipboard-paste-protection = true

# Tmux compatibility: unbind keys that conflict with Ctrl-h/j/k/l pane nav
# and Alt-Left/Right window cycling
keybind = ctrl+h=unbind
keybind = ctrl+j=unbind
keybind = ctrl+k=unbind
keybind = ctrl+l=unbind
keybind = alt+left=unbind
keybind = alt+right=unbind
