# Theme
theme = Xcode Dark hc

# Font
font-family = FiraCode Nerd Font Mono
font-size = 16
font-style = Reg
font-style-bold = Bold
font-style-italic = Reg
font-style-bold-italic = Bold
font-feature = -calt
font-feature = -liga
font-thicken = true

# Cursor
cursor-style = block
cursor-style-blink = false

# Shell integration
shell-integration = detect

# Window
window-padding-x = 4
window-padding-y = 4
confirm-close-surface = false
window-inherit-working-directory = false

# Notifications
notify-on-command-finish = unfocused
notify-on-command-finish-action = notify
notify-on-command-finish-after = 10s

# macOS
macos-titlebar-style = native
macos-titlebar-proxy-icon = visible
macos-icon = custom
# Keep the custom icon next to the Ghostty config so the path stays obvious.
macos-custom-icon = ~/.config/ghostty/catppuccin-mocha.icns

# Input
mouse-hide-while-typing = true
copy-on-select = true
clipboard-paste-protection = true

# scrollback-limit in bytes, roughly 125,000 lines
scrollback-limit = 100000000
